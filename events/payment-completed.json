{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PaymentCompleted",
  "description": "Published when a payment transaction completes",
  "type": "object",
  "properties": {
    "event_type": { "const": "payment.completed" },
    "event_id": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "properties": {
        "transaction_id": { "type": "string", "format": "uuid" },
        "user_id": { "type": "string", "format": "uuid" },
        "recipient_id": { "type": "string", "format": "uuid" },
        "amount": { "type": "string" },
        "currency": { "type": "string" },
        "type": { "type": "string", "enum": ["donation", "subscription"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["transaction_id", "user_id", "amount", "currency", "type", "created_at"]
    }
  },
  "required": ["event_type", "event_id", "timestamp", "data"]
}
