{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NotificationTrigger",
  "description": "Internal event to trigger a notification for a user",
  "type": "object",
  "properties": {
    "event_type": { "const": "notification.trigger" },
    "event_id": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "properties": {
        "recipient_id": { "type": "string", "format": "uuid" },
        "type": { "type": "string", "enum": ["like", "comment", "follow", "mention", "message"] },
        "actor_id": { "type": "string", "format": "uuid" },
        "reference_id": { "type": "string" }
      },
      "required": ["recipient_id", "type", "actor_id"]
    }
  },
  "required": ["event_type", "event_id", "timestamp", "data"]
}
